# ──────────────────────────────────────────────────────────────
# CafeFlow SaaS — Environment Configuration (MySQL edition)
# Copy to .env and fill in. The original spec used PostgreSQL;
# this build uses MySQL per project requirement.
# ──────────────────────────────────────────────────────────────

# Database (MySQL 8)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://cafeflow:cafeflow@localhost:3306/cafeflow"

# Auth — JWT signing secret (use: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-32-char-random-string"
AUTH_URL="http://localhost:3000"
# Session lifetime in hours
SESSION_TTL_HOURS=8760

# SaaS subscription config
SAAS_SUBSCRIPTION_AMOUNT=30000
SAAS_SUBSCRIPTION_DAYS=180
SAAS_TRIAL_DAYS=7
SAAS_GRACE_PERIOD_DAYS=3
SAAS_WARNING_DAYS=7
SAAS_BANK_NAME="Commercial Bank of Ethiopia"
SAAS_ACCOUNT_NUMBER="1000XXXXXXXXX"
SAAS_ACCOUNT_NAME="CafeFlow Technologies"

# Ethiopian VAT
VAT_RATE=0.15

# ── Integrations ──
# Payments: ALL methods (Cash / Telebirr / CBE Birr) are DEMO/simulated in this
# build — no real provider integration, no credentials required. Payments are
# confirmed via the webhook endpoints and persisted to MySQL.

# Realtime/KDS: MySQL-backed. Clients poll MySQL-backed endpoints; no Firebase.

# Email (Resend) — set the key to send real email; otherwise logs to console.
RESEND_API_KEY=
EMAIL_FROM="noreply@cafeflow.app"

# Local file storage dir for uploaded receipts (path is recorded in MySQL).
RECEIPT_STORAGE_DIR="./.uploads"
